# Firebase Admin SDK — path to the service account JSON file you downloaded
# (Firebase Console → Project Settings → Service Accounts → Generate New Private Key)
GOOGLE_APPLICATION_CREDENTIALS=./.firebase-service-account.json

# OpenRouter API key — for LLM calls (extraction, heading correction, schema wizard)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx

# LLM fallback chain (via OpenRouter) — order matters
# Primary: Grok (retry within before falling back)
OPENROUTER_MODEL_PRIMARY=x-ai/grok-4.20
# Fallback: Gemini Flash Lite (retry within before permanent failure)
OPENROUTER_MODEL_FALLBACK=google/gemini-3.1-flash-lite-preview

# MinerU API — local REST API for OCR processing
# Default: http://127.0.0.1:8765 (started via `mineru-api` command)
MINERU_API_URL=http://127.0.0.1:8765

# Firebase Web SDK config (for admin web app — Google Auth)
# (Firebase Console → Project Settings → General → Your apps → Web app config)
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx

# Admin email — only this Google account can access the admin web app
ADMIN_EMAIL=adnan@thothica.com

# App environment
NODE_ENV=development
