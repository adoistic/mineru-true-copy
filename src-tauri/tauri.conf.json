{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "DocTransform",
  "version": "0.1.0",
  "identifier": "com.doctransform.app",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://localhost:60549",
    "beforeBuildCommand": "cd app && npm run build",
    "frontendDist": "splash.html"
  },
  "app": {
    "windows": [
      {
        "title": "DocTransform",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/icon.icns",
      "icons/icon.png"
    ],
    "externalBin": [],
    "resources": ["../lib/fonts/font_classifier.onnx"]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
